# This file documents local configuration names only.
# The static site does not load .env files automatically.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_FUNCTION_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/submit-message
ALLOWED_PUBLISHABLE_KEYS=YOUR_SUPABASE_PUBLISHABLE_KEY
ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,https://YOUR_PUBLIC_SITE.example

# Configure privileged values such as SUPABASE_SERVICE_ROLE_KEY and
# IP_HASH_SALT directly as Supabase Edge Function secrets. Never expose them
# in browser JavaScript or commit them to an environment file.
