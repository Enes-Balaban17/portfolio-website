# This file documents configuration names for maintainers.
# The static website does not load .env files automatically.

# Supabase public browser configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key_here
SUPABASE_FUNCTION_URL=https://your-project-ref.supabase.co/functions/v1/submit-message

# Supabase Edge Function runtime configuration
# Keep these values in Supabase secrets or another server-only runtime.
# Never expose them in browser JavaScript.
SUPABASE_SERVICE_ROLE_KEY=REPLACE_THIS_ONLY_IN_SERVER_OR_FUNCTION_RUNTIME
IP_HASH_SALT=REPLACE_THIS_ONLY_IN_SERVER_OR_FUNCTION_RUNTIME
ALLOWED_PUBLISHABLE_KEYS=sb_publishable_your_public_key_here
ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,https://enesbalaban.dev

